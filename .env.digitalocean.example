# Public hostnames
DOMAIN_NAME=example.com
API_DOMAIN_NAME=api.example.com

# Public URLs
# FRONTEND_ORIGIN also accepts a comma-separated list.
# Use "*" if you need the same API to work from the public domain, raw IP,
# localhost, and multiple UI hosts without CORS breakage.
FRONTEND_ORIGIN=*
PUBLIC_BASE_URL=https://api.example.com
API_BASE_URL=https://api.example.com

# Storage
ARTIFACT_ROOT=/data/comment-data/artifacts
ARTIFACT_URL_BASE_PATH=/artifacts
# Model artifacts — must point to a persistent volume path or models are lost on container restart
MODEL_ARTIFACT_ROOT=/data/comment-data/artifacts/models

# Data services
POSTGRES_DB=comment_data_collection
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://postgres:change-me@postgres:5432/comment_data_collection
REDIS_URL=redis://redis:6379

# Scanner pacing
WORKER_CONCURRENCY=4
SCAN_TIMEOUT_MS=90000
POST_LOAD_DELAY_MS=750
PRE_SCREENSHOT_DELAY_MS=250
NAVIGATION_RETRIES=2
LOAD_SETTLE_PASSES=1
NEGATIVE_RETRY_SETTLE_PASSES=1
ACTION_SETTLE_MS=350

# Queue / ingestion
INITIAL_QUEUE_FILL=8
QUEUE_REFILL_COUNT=4
QUEUE_RECOVERY_INTERVAL_MS=30000
INGEST_BATCH_SIZE=250
API_RESULTS_PAGE_SIZE=100

# Advanced BullMQ lock tuning
# Leave these unset unless you need to override the derived defaults.
# WORKER_LOCK_DURATION_MS=180000
# WORKER_LOCK_RENEW_TIME_MS=90000
# WORKER_STALLED_INTERVAL_MS=90000
# WORKER_MAX_STALLED_COUNT=2

# Artifacts
CAPTURE_SCREENSHOTS=true
CAPTURE_HTML_SNAPSHOTS=true

# Optional email notifications
EMAIL_NOTIFICATIONS_ENABLED=false
JOB_NOTIFICATION_TO=you@example.com
SMTP_FROM=ugc-scanner@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
