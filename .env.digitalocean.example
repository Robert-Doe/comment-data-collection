# Host ports
UI_PORT=8080
API_PORT=3000

# Public URLs
FRONTEND_ORIGIN=http://YOUR_DROPLET_IP:8080
PUBLIC_BASE_URL=http://YOUR_DROPLET_IP:3000
API_BASE_URL=http://YOUR_DROPLET_IP:3000

# Storage
ARTIFACT_ROOT=/data/comment-data/artifacts
ARTIFACT_URL_BASE_PATH=/artifacts

# Data services
POSTGRES_DB=comment_data_collection
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://postgres:change-me@postgres:5432/comment_data_collection
REDIS_URL=redis://redis:6379

# Scanner pacing
WORKER_CONCURRENCY=2
SCAN_TIMEOUT_MS=90000
POST_LOAD_DELAY_MS=750
PRE_SCREENSHOT_DELAY_MS=250
NAVIGATION_RETRIES=2
LOAD_SETTLE_PASSES=1
NEGATIVE_RETRY_SETTLE_PASSES=1
ACTION_SETTLE_MS=350

# Queue / ingestion
INITIAL_QUEUE_FILL=4
QUEUE_REFILL_COUNT=2
QUEUE_RECOVERY_INTERVAL_MS=30000
INGEST_BATCH_SIZE=250
API_RESULTS_PAGE_SIZE=100

# Advanced BullMQ lock tuning
# Leave these unset unless you need to override the derived defaults.
# WORKER_LOCK_DURATION_MS=180000
# WORKER_LOCK_RENEW_TIME_MS=90000
# WORKER_STALLED_INTERVAL_MS=90000
# WORKER_MAX_STALLED_COUNT=2

# Artifacts
CAPTURE_SCREENSHOTS=true
CAPTURE_HTML_SNAPSHOTS=true
