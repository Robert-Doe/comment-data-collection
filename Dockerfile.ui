FROM node:22-bookworm-slim AS build

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

# Build version can still be baked in; API URL is injected at runtime.
ARG BUILD_VERSION=""
ENV BUILD_VERSION=${BUILD_VERSION}

RUN npm run build:ui

FROM nginx:1.27-alpine

COPY deploy/nginx.ui.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/web /usr/share/nginx/html

# Entrypoint writes config.js from runtime env before nginx starts.
COPY scripts/docker-entrypoint-ui.sh /docker-entrypoint.d/40-write-config.sh
RUN chmod +x /docker-entrypoint.d/40-write-config.sh
