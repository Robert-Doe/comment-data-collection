{
  "manifest_version": 3,
  "name": "PseudoDOM Guard",
  "version": "0.1.0",
  "description": "Pre-execution DOM interception for XSS prevention via PseudoDOM construction and UGC region localization.",

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "debugger",
    "webRequest"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content_bridge.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "action": {
    "default_popup": "src/ui/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "web_accessible_resources": [
    {
      "resources": ["src/core/injected_wrapper.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
